# .gitignore
.env
.env.local
.env.*.local

# Test artifacts
test_dashboard.html

# Python cache files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
# Python-standard patterns above accidentally match our web SPA's
# src/lib/ — make the frontend's lib explicit again.
!web/src/lib/
!web/src/lib/**
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
pytest-cache-files-*/

# PyCharm
.idea/
.vscode/
*.swp
*.swo

# macOS
.DS_Store

# Virtual environments
.venv/
venv/
env/

# Convenience scripts (personal)
run.sh

# DeepSeek Agent specific
# .claude/ — allow committing skills, ignore session-local state
.claude/settings.local.json
.claude/projects/
.claude/cache/
.claude/logs/
.claude/scheduled_tasks.lock
.user/

# Safety audit logs
*.safety_audit.log

# Secrets / credentials — NEVER check in
*.pem
*.key
*.secret
*.p12
*.pfx
*.keystore
*.jks
credentials.json
token.json
service_account*.json
# TokenSight (local only)
tokensight/

# Environment files — catch all variants
.env.*
!.env.example

# SQLite databases (contain user data / financial data)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Data directories (financial data, predictions, personal analysis)
/data/
backups/

# Personal notes / private analysis
private/
personal/
*.private.*

# SSH / GPG keys
id_rsa*
id_ed25519*
*.gpg

# OS credential stores
.netrc
.npmrc
.pypirc

# Test mock artifacts (leaked by MagicMock in tests)
<MagicMock*

# Architecture visualization (local reference only)
plans/architecture_interactive.html
plans/ARCHITECTURE_VISUALIZATION.md

# Dev reports & temp docs (keep local, never commit)
COMPREHENSIVE_TESTS_SUMMARY.md
COMPREHENSIVE_TEST_REPORT.txt
DASHBOARD_README.md
TESTS_CREATED.md
TESTS_INDEX.md
TESTS_QUICK_REFERENCE.md
TEST_FILES_SUMMARY.txt
TEST_SUITE_SUMMARY.md
tests/COMPLETION_REPORT.txt
tests/TEST_COVERAGE_SUMMARY.md

# Backup & temp scripts
agent/core.py.bak
*.backup_[0-9]*
test_search_status.py
neomind/test.txt
.env

# Junk artifacts (sometimes created by buggy tools / shell quoting bugs)
echo "__IKOL_*"
__IKOL_*
*.tar.gz
files.txt
test.py
test_session_*
singleton_example.py

# NeoMind runtime artifacts (user data, never commit)
.neomind_snips/
.neomind_tool_outputs/
.neomind/
test_dashboard.html

# Top-level dev notes (keep local)
BUG_REPORTS.md
PROGRESS_summary.md
IMPLEMENTATION_SUMMARY.md
FEATURE_LIST.md
TESTING_GUIDE.md
FIX_LOG.md
# But keep the qa_archive FIX_LOG tracked — it's a canonical audit trail
# documented in tests/qa_archive/README.md as part of the archive layout.
!tests/qa_archive/FIX_LOG.md

# Phase D / canary-deploy host-side evolution state (2026-04-11)
.host_evolution_data/
.mycontext
.venv-host/

# C1 — episode capture jsonl (manual reflect input, not source-of-truth)
_evolution/
