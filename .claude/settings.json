{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/bin/python tools/hooks/iterm2_safety_hook.py"
          },
          {
            "type": "command",
            "command": ".venv/bin/python tools/hooks/leak_scan_hook.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/bin/python tools/hooks/file_write_leak_scan.py"
          }
        ]
      }
    ]
  }
}
