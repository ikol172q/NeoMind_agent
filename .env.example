# Environment variables for DeepSeek AI Agent
# Copy this file to .env and fill in your API key

# Required: Your DeepSeek API key from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_api_key_here

# Optional: Configuration overrides
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_TEMPERATURE=0.7

# Claude Code integration (if using Claude Code)
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your_deepseek_api_key_here
# API_TIMEOUT_MS=600000
# ANTHROPIC_MODEL=deepseek-reasoner
# ANTHROPIC_SMALL_FAST_MODEL=deepseek-chat
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1