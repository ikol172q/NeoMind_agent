# Environment variables for neomind Agent
# Copy this file to .env and fill in your API key(s)

# Required: At least one provider API key
# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# z.ai (GLM models) — https://open.z.ai
ZAI_API_KEY=your_zai_api_key_here

# Optional: Configuration overrides
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_TEMPERATURE=0.7

# ── Finance Mode (optional — fin mode works without these, using free sources) ──
# Finnhub — https://finnhub.io/register (free tier: 60 calls/min)
# FINNHUB_API_KEY=your_finnhub_api_key_here

# Tavily Search — https://tavily.com (optional, upgrades search quality)
# TAVILY_API_KEY=your_tavily_api_key_here

# Serper — https://serper.dev (optional, Google search results)
# SERPER_API_KEY=your_serper_api_key_here

# NewsAPI.org — https://newsapi.org (optional, 100 req/day free, excellent for financial news)
# NEWSAPI_API_KEY=your_newsapi_api_key_here

# SearXNG — self-hosted (optional, privacy-focused meta-search)
# SEARXNG_URL=http://localhost:8888

# ── Telegram Bot (run NeoMind as independent bot in Telegram groups) ──
# Create via @BotFather on Telegram, get the token
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# OpenClaw's Telegram bot username (for @mention delegation between agents)
# OPENCLAW_TELEGRAM_USERNAME=openclaw_bot

# Restrict bot to specific group chat IDs (comma-separated, empty = all groups)
# TELEGRAM_ALLOWED_GROUPS=-1001234567890

# Admin user IDs who can run privileged commands (comma-separated)
# TELEGRAM_ADMIN_USERS=123456789

# Auto-detect financial questions without @mention (true/false, default: true)
# TELEGRAM_AUTO_DETECT=true

# ── OpenClaw Integration (optional — enables cross-platform messaging) ──
# OpenClaw Gateway URL (default: ws://127.0.0.1:18789)
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# OpenClaw device token (get from OpenClaw after pairing)
# OPENCLAW_DEVICE_TOKEN=your_openclaw_token_here

# OpenClaw memory directory (default: ~/.openclaw/memory)
# OPENCLAW_MEMORY_DIR=~/.openclaw/memory

# Mobile Sync port for standalone mode (default: 18790)
# NEOMIND_SYNC_PORT=18790

# Claude Code integration (if using Claude Code)
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your_deepseek_api_key_here
# API_TIMEOUT_MS=600000
# ANTHROPIC_MODEL=deepseek-reasoner
# ANTHROPIC_SMALL_FAST_MODEL=deepseek-chat
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1