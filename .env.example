# Environment variables for neomind Agent
# Copy this file to .env and fill in your API key(s)

# Required: At least one provider API key
# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# z.ai (GLM models) — https://open.z.ai
ZAI_API_KEY=your_zai_api_key_here

# ── LiteLLM + Ollama (optional — local models, zero cost) ──
# Provider mode is now controlled via provider-state.json (shared with xbar).
# Use the xbar menu or /provider command in Telegram to switch modes.
# LITELLM_ENABLED is still supported for backward compatibility on first run.
# LITELLM_ENABLED=true
# LITELLM_API_KEY=sk-your-secret-key-here
# LITELLM_BASE_URL=http://host.docker.internal:4000/v1

# ── TokenSight Proxy (usage tracking) ──
# Route API calls through TokenSight for token/cost monitoring.
# TOKENSIGHT_PROXY_URL=http://host.docker.internal:8900

# ── Provider State Sync ──
# Shared directory for provider-state.json (bidirectional sync between xbar and bot)
# Default: ~/.neomind (bind-mounted into Docker container)
# NEOMIND_STATE_DIR=~/.neomind

# Optional: Configuration overrides
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_TEMPERATURE=0.7

# ── Search Sources (optional — search works without these using DDG + Google News RSS) ──
# Each key adds a parallel search source. More sources = better quality via RRF fusion.
#
# Brave Search — https://brave.com/search/api/ (independent 30B+ page index, $5 credit on signup)
# BRAVE_API_KEY=your_brave_api_key_here
#
# Serper — https://serper.dev (fastest Google SERP, 2500 free on signup)
# SERPER_API_KEY=your_serper_api_key_here
#
# Tavily — https://tavily.com (AI-optimized search, 1000/month free)
# TAVILY_API_KEY=your_tavily_api_key_here
#
# Jina AI — https://jina.ai/reader/ (semantic search + content extraction)
# JINA_API_KEY=your_jina_api_key_here
#
# NewsAPI.org — https://newsapi.org (100 req/day free, excellent for news)
# NEWSAPI_API_KEY=your_newsapi_api_key_here
#
# Exa.ai — https://exa.ai (neural/semantic search, 1000 credits on signup)
# EXA_API_KEY=your_exa_api_key_here
#
# You.com — https://you.com (93% SimpleQA accuracy, MCP support)
# YOUCOM_API_KEY=your_youcom_api_key_here
#
# Perplexity Sonar — https://docs.perplexity.ai/ (LLM-generated answers with citations)
# PERPLEXITY_API_KEY=your_perplexity_api_key_here
#
# Cohere Rerank — https://cohere.com (high-accuracy semantic reranker, +20-35%)
# COHERE_API_KEY=your_cohere_api_key_here
#
# SearXNG — self-hosted (privacy-focused meta-search, unlimited)
# SEARXNG_URL=http://localhost:8888

# ── Finance Mode (optional — fin mode works without these, using free sources) ──
# Finnhub — https://finnhub.io/register (free tier: 60 calls/min)
# FINNHUB_API_KEY=your_finnhub_api_key_here

# ── Telegram Bot (run NeoMind as independent bot in Telegram groups) ──
# Create via @BotFather on Telegram, get the token
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# OpenClaw's Telegram bot username (for @mention delegation between agents)
# OPENCLAW_TELEGRAM_USERNAME=openclaw_bot

# Restrict bot to specific group chat IDs (comma-separated, empty = all groups)
# TELEGRAM_ALLOWED_GROUPS=-1001234567890

# Admin user IDs who can run privileged commands (comma-separated)
# TELEGRAM_ADMIN_USERS=123456789

# Auto-detect financial questions without @mention (true/false, default: true)
# TELEGRAM_AUTO_DETECT=true

# ── Canary bot (zero-downtime self-evolution, optional) ──
# Only needed if running the neomind-canary Docker profile.
# See docs/CANARY_BOT_SETUP.md for full walkthrough.
#
# Fresh test bot token from @BotFather (NOT your production TELEGRAM_BOT_TOKEN):
# TELEGRAM_TEST_BOT_TOKEN=
#
# Canary bot whitelist: comma-separated Telegram user IDs allowed to DM the
# canary bot. Prevents random users from burning LLM tokens if they discover
# the bot. Message @userinfobot to find your personal Telegram user ID.
# If unset, falls back to TELEGRAM_ADMIN_USERS (simpler but couples the two).
# NEOMIND_CANARY_ALLOWED_USERS=12345,67890

# ── OpenClaw Integration (optional — enables cross-platform messaging) ──
# OpenClaw Gateway URL (default: ws://127.0.0.1:18789)
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# OpenClaw device token (get from OpenClaw after pairing)
# OPENCLAW_DEVICE_TOKEN=your_openclaw_token_here

# OpenClaw memory directory (default: ~/.openclaw/memory)
# OPENCLAW_MEMORY_DIR=~/.openclaw/memory

# Mobile Sync port for standalone mode (default: 18790)
# NEOMIND_SYNC_PORT=18790

# Claude Code integration (if using Claude Code)
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your_deepseek_api_key_here
# API_TIMEOUT_MS=600000
# ANTHROPIC_MODEL=deepseek-reasoner
# ANTHROPIC_SMALL_FAST_MODEL=deepseek-chat
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1