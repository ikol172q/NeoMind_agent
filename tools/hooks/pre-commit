#!/bin/bash
# NeoMind cross-mode pre-commit smoke
#
# Triggers: when staged changes touch shared code paths that affect multiple
# modes (chat / fin / coding). Runs a fast boot smoke for each mode (~90s
# total) to catch regressions before they reach main.
#
# Bypass for emergencies:  NEOMIND_SKIP_SMOKE=1 git commit ...
#
# Install (one-time per clone):  ./tools/hooks/install.sh

set -e

if [ -n "$NEOMIND_SKIP_SMOKE" ]; then
    echo "[neomind-pre-commit] SKIP (NEOMIND_SKIP_SMOKE=1)"
    exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Shared code paths — change here if mode-cutting modules move
SHARED_REGEX='^(agent/services/code_commands\.py|agent/services/nl_interpreter\.py|agent/core\.py|agent/agentic/agentic_loop\.py|agent/integration/telegram_bot\.py|agent/coding/tools\.py|agent/config/.*\.yaml|agent/config\.yaml)$'

# Insight Lattice paths — any change here must pass the fast
# validation suite (spec contract + formulas + graph builder +
# fixture drift). Budget: <5s. See plans/2026-04-22_lattice-validation.md.
LATTICE_REGEX='^(agent/finance/lattice/.*\.py|agent/config/lattice_taxonomy\.yaml|tests/test_lattice_.*\.py|tests/lattice_fixtures/.*\.json)$'

# Fin data-platform paths — persistence + scheduler + integrity. Any
# change here triggers the live integrity check ("13/13 pass" against
# the local DB). Budget: <2s on a small DB. Skipped if no DB exists
# yet (fresh clone before first scheduler run). Bypass shared with
# lattice/smoke flags.
FIN_PLATFORM_REGEX='^(agent/finance/(persistence|scheduler|integrity)/.*\.py)$'

CHANGED=$(git diff --cached --name-only)

# Lattice validation runs first because it's much faster
if echo "$CHANGED" | grep -qE "$LATTICE_REGEX"; then
    echo "[neomind-pre-commit] Lattice paths changed — running fast validation..."
    if ! make validate-algorithm-only >/dev/null 2>&1; then
        echo ""
        echo "❌ [neomind-pre-commit] Lattice fast validation FAILED"
        echo "   Run: make validate-algorithm-only   for details"
        echo "   Bypass: NEOMIND_SKIP_SMOKE=1 git commit ..."
        exit 1
    fi
    echo "✅ [neomind-pre-commit] Lattice fast validation passed"
fi

# Fin data-platform integrity check
if echo "$CHANGED" | grep -qE "$FIN_PLATFORM_REGEX"; then
    # Resolve DB path the same way agent/finance/persistence/db.py does
    FIN_DB="${NEOMIND_FIN_DB:-$HOME/.neomind/fin/fin.db}"
    if [ ! -f "$FIN_DB" ]; then
        echo "[neomind-pre-commit] fin DB not found at $FIN_DB — skipping integrity"
        echo "                     (run scheduler once to populate, then re-commit)"
    else
        echo "[neomind-pre-commit] fin platform paths changed — running integrity check..."
        if ! .venv/bin/python -m agent.finance.integrity.runner --fail-on-error >/dev/null 2>&1; then
            echo ""
            echo "❌ [neomind-pre-commit] fin integrity check FAILED"
            echo "   Run: .venv/bin/python -m agent.finance.integrity.runner   for details"
            echo "   Bypass: NEOMIND_SKIP_SMOKE=1 git commit ..."
            exit 1
        fi
        echo "✅ [neomind-pre-commit] fin integrity check passed"
    fi
fi

if ! echo "$CHANGED" | grep -qE "$SHARED_REGEX"; then
    # No shared paths touched — fast pass
    exit 0
fi

echo "[neomind-pre-commit] Shared paths changed — running cross-mode boot smoke..."
echo "[neomind-pre-commit] (bypass: NEOMIND_SKIP_SMOKE=1 git commit ...)"
echo ""

# Use timeout to bound worst-case (4 min hard cap)
if command -v gtimeout >/dev/null 2>&1; then
    TIMEOUT=gtimeout
elif command -v timeout >/dev/null 2>&1; then
    TIMEOUT=timeout
else
    TIMEOUT=""
fi

if [ -n "$TIMEOUT" ]; then
    $TIMEOUT 240 .venv/bin/python tests/integration/cross_mode_boot_smoke.py
else
    .venv/bin/python tests/integration/cross_mode_boot_smoke.py
fi
RC=$?

if [ $RC -ne 0 ]; then
    echo ""
    echo "❌ [neomind-pre-commit] Cross-mode smoke FAILED (exit $RC)"
    echo "   Either fix the regression or set NEOMIND_SKIP_SMOKE=1 if intentional."
    exit $RC
fi

echo "✅ [neomind-pre-commit] Cross-mode smoke passed"
exit 0
